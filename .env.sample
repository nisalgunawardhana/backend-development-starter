# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/backend_starter
# For MongoDB Atlas (Cloud), use format like:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/backend_starter?retryWrites=true&w=majority

# Database Name
DB_NAME=backend_starter

# Instructions:
# 1. Copy this file to .env: cp .env.sample .env
# 2. Update MONGODB_URI with your actual MongoDB connection string
# 3. IMPORTANT: Never commit your .env file to version control!